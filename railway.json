{
  "$schema": "https://railway.app/config.schema.json",
  "services": {
    "backend": {
      "rootDirectory": "Backend",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "npm start",
        "restartPolicyMaxRetries": 5
      }
    },
    "frontend": {
      "rootDirectory": "Frontend",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "npm run build && npm install -g serve && serve -s dist -l 3000",
        "restartPolicyMaxRetries": 5
      }
    }
  }
}
